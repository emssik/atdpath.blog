---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Datetime from "@/components/Datetime.astro";
import PageHero from "@/components/PageHero.astro";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import ShareButtons from "@/components/ShareButtons.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import { difficultyLabel } from "@/utils/difficultyLabel";
import BuyCoffeeButton from "@/components/BuyCoffeeButton.astro";

export async function getStaticPaths() {
  const projects = await getCollection("piy");
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({
      params: { slug: project.id },
      props: { project },
    }));
}

type Props = { project: CollectionEntry<"piy"> };

const { project } = Astro.props;
const { title, description, pubDatetime, repo, tags, difficulty } = project.data;
const { Content } = await render(project);
const ogImage = `/piy/${project.id}.png`;
---

<Layout title={title} description={description} ogImage={ogImage}>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-6 pb-12">
    <article>
      <header class="mb-10">
        <PageHero kicker="PIY — Prompt It Yourself" subtitle={description}>
          {title}
        </PageHero>
        <div class="flex items-center justify-center gap-4">
          {difficulty && (
            <span class="text-sm text-subtle">
              {difficultyLabel[difficulty] ?? difficulty}
            </span>
          )}
          {repo && (
            <a
              href={repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-accent transition-colors hover:text-accent/70"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
              Repozytorium
            </a>
          )}
          <BuyCoffeeButton />
        </div>
        <hr class="my-4 border-muted" />
        <div class="flex flex-wrap items-center justify-center gap-3">
          {tags.map((tag) => (
            <Tag tag={tag} />
          ))}
        </div>
        <hr class="my-4 border-muted" />
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    <NewsletterForm />

    <hr class="my-8 border-dashed" />

    <div class="flex items-center justify-between flex-wrap gap-4 my-6">
      <ul class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li>
            <Tag tag={tag} />
          </li>
        ))}
      </ul>
      <ShareButtons title={title} description={description} slug={`piy/${project.id}`} prefix="" />
    </div>
  </main>
  <Footer />
</Layout>
