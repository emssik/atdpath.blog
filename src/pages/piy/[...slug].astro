---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Datetime from "@/components/Datetime.astro";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("piy");
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({
      params: { slug: project.id },
      props: { project },
    }));
}

type Props = { project: CollectionEntry<"piy"> };

const { project } = Astro.props;
const { title, description, pubDatetime, repo, tags, difficulty } = project.data;
const { Content } = await render(project);

const difficultyLabel: Record<string, string> = {
  beginner: "Początkujący",
  intermediate: "Średniozaawansowany",
  advanced: "Zaawansowany",
};
---

<Layout title={`${title} | PIY`} description={description}>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-6 pb-12 mt-8">
    <article>
      <header class="mb-10">
        <a
          href="/piy"
          class="mb-6 inline-flex items-center gap-1 text-sm text-subtle transition-colors hover:text-accent"
        >
          <span aria-hidden="true">&larr;</span>
          PIY
        </a>
        <h1 class="inline-block text-2xl font-bold text-accent sm:text-3xl">
          {title}
        </h1>
        <div class="flex items-center gap-3 mt-2">
          <Datetime {pubDatetime} size="lg" />
        </div>
        <p class="mt-3 text-subtle leading-relaxed">{description}</p>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          {difficulty && (
            <span class="rounded-full bg-muted px-3 py-1 text-xs text-subtle">
              {difficultyLabel[difficulty] ?? difficulty}
            </span>
          )}
          {tags.map((tag) => (
            <span class="text-xs text-subtle">#{tag}</span>
          ))}
          {repo && (
            <a
              href={repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full bg-muted px-3 py-1 text-xs text-accent transition-colors hover:bg-accent/10"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
              Repozytorium
            </a>
          )}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Layout>
