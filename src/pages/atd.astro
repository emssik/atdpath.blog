---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Datetime from "@/components/Datetime.astro";
import Layout from "@/layouts/Layout.astro";

const lastUpdated = new Date("2026-03-07");
---

<Layout title="AI Things Done (ATD)" description="AI Things Done (ATD)">
  <Header />
  <main id="main-content">
    <section class="pt-8 pb-12">
      <h1 class="inline-block text-2xl font-bold text-accent sm:text-3xl">AI Things Done (ATD)</h1>
      <div class="flex items-center gap-3 mt-2 mb-8">
        <Datetime pubDatetime={lastUpdated} size="lg" />
      </div>
      <div class="prose">
        <p>
          Edytuj plik <code>src/pages/atd.astro</code> aby dodac wlasna tresc.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
