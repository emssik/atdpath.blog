---
import { getCollection } from "astro:content";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getSortedProjects from "@/utils/getSortedProjects";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const blogData = sortedPosts.map(({ id, data }) => ({
  slug: id,
  title: data.title,
  description: data.description,
  tags: data.tags,
  date: data.pubDatetime.toISOString(),
  type: "post" as const,
}));

const projects = await getCollection("piy");
const sortedProjects = getSortedProjects(projects);
const piyData = sortedProjects.map(({ id, data }) => ({
  slug: id,
  title: data.title,
  description: data.description,
  tags: data.tags,
  date: data.pubDatetime.toISOString(),
  type: "piy" as const,
}));

// Workaround for GHSA-j687-52p2-xcff (astro < 6.1.6 define:vars XSS).
// Remove after the Astro 6.x upgrade (top5 ATD-27 / ATD-28).
const escapeForInlineScript = (s: string) => s.replace(/<\/(script)/gi, "<\\/$1");

const searchData = [...blogData, ...piyData]
  .map((item) => ({
    ...item,
    title: escapeForInlineScript(item.title),
    description: escapeForInlineScript(item.description),
    tags: item.tags.map(escapeForInlineScript),
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Search" description="Search blog posts.">
  <Header />
  <main id="main-content">
    <section class="pt-8 pb-12">
      <h1 class="mb-6 text-2xl font-bold">Search</h1>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 opacity-50" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search posts and projects..."
          class="w-full rounded-lg border border-border bg-muted/50 py-3 pl-10 pr-4 text-sm text-foreground placeholder:text-subtle outline-none focus:border-accent transition-colors"
          autofocus
        />
      </div>
      <ul id="search-results" class="mt-6"></ul>
      <p id="search-empty" class="mt-8 text-center text-subtle hidden">
        No results found.
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline define:vars={{ searchData }}>
  const input = document.getElementById("search-input");
  const resultsList = document.getElementById("search-results");
  const emptyMsg = document.getElementById("search-empty");

  const searchIndex = searchData.map((post) => ({
    ...post,
    _title: post.title.toLowerCase(),
    _description: post.description.toLowerCase(),
    _tags: post.tags.map((t) => t.toLowerCase()),
  }));

  function clearResults() {
    resultsList.replaceChildren();
  }

  function renderResult(post) {
    const li = document.createElement("li");
    li.className = "my-6";

    const a = document.createElement("a");
    a.href = `${post.type === "piy" ? "/piy" : "/posts"}/${post.slug}`;
    a.className =
      "inline-block text-accent decoration-dashed underline-offset-4 focus-visible:no-underline";

    const h3 = document.createElement("h3");
    h3.className = "text-base font-medium decoration-dashed hover:underline";
    h3.textContent = `${post.type === "piy" ? "[PIY] " : ""}${post.title}`;
    a.appendChild(h3);

    const p = document.createElement("p");
    p.className = "mt-1 opacity-80";
    p.textContent = post.description;

    li.appendChild(a);
    li.appendChild(p);
    return li;
  }

  function search(query) {
    if (!query || query.length < 2) {
      clearResults();
      emptyMsg.classList.add("hidden");
      return;
    }

    const q = query.toLowerCase();
    const results = searchIndex.filter(
      (post) =>
        post._title.includes(q) ||
        post._description.includes(q) ||
        post._tags.some((tag) => tag.includes(q))
    );

    clearResults();

    if (results.length === 0) {
      emptyMsg.classList.remove("hidden");
      return;
    }

    emptyMsg.classList.add("hidden");
    for (const post of results) {
      resultsList.appendChild(renderResult(post));
    }
  }

  input?.addEventListener("input", (e) => search(e.target.value));

  // Focus search on / key
  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement !== input) {
      e.preventDefault();
      input?.focus();
    }
  });
</script>
