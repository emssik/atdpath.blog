---
import { SITE, NAV_LINKS } from "@/config";

const { pathname } = Astro.url;
const currentPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  const currentPathArray = currentPath.split("/").filter((p) => p.trim());
  const pathArray = path.split("/").filter((p) => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<header class="fixed top-0 left-0 right-0 z-[999] border-b border-border bg-background">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-6">
    <a href="/" class="font-display text-xl font-bold tracking-tight transition-colors hover:text-accent">
      {SITE.title}
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-6">
      {NAV_LINKS.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "font-body text-base tracking-wide transition-colors hover:text-accent",
            { "active-nav": isActive(href) },
          ]}
        >
          {label}
        </a>
      ))}
      <div class="ml-2 flex items-center gap-3 border-l border-border pl-4">
        <a
          href="/ai"
          class:list={[
            "font-body text-xs tracking-wide text-subtle transition-colors hover:text-accent",
            { "active-nav": isActive("/ai") },
          ]}
        >
          AI
        </a>
      </div>
      <a
        href="/search"
        class="text-subtle transition-colors hover:text-accent"
        aria-label="Search"
        title="Search"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
      </a>
      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="relative size-8 rounded-full transition-colors hover:bg-muted"
          title="Toggle theme"
          aria-label="Toggle theme"
        >
          <svg class="sun-icon absolute inset-0 m-auto size-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
          <svg class="moon-icon absolute inset-0 m-auto size-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      )}
    </div>

    <!-- Mobile: theme toggle + hamburger -->
    <div class="flex items-center gap-3 sm:hidden">
      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn-mobile"
          class="relative size-8 rounded-full transition-colors hover:bg-muted"
          title="Toggle theme"
          aria-label="Toggle theme"
        >
          <svg class="sun-icon absolute inset-0 m-auto size-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
          <svg class="moon-icon absolute inset-0 m-auto size-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      )}
      <button
        id="menu-btn"
        class="size-8 flex items-center justify-center rounded-full transition-colors hover:bg-muted"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-border">
    <div class="mx-auto max-w-3xl px-6 py-4 flex flex-col gap-3">
      {NAV_LINKS.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "font-body text-base py-1 transition-colors hover:text-accent",
            { "text-accent": isActive(href) },
          ]}
        >
          {label}
        </a>
      ))}
      <div class="flex items-center gap-4 pt-2 border-t border-border">
        <a
          href="/ai"
          class:list={[
            "font-body text-xs text-subtle transition-colors hover:text-accent",
            { "text-accent": isActive("/ai") },
          ]}
        >
          AI
        </a>
        <a href="/search" class="text-subtle transition-colors hover:text-accent text-sm">
          Search
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  function setupMobileMenu() {
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");
    if (!btn || !menu || !menuIcon || !closeIcon) return;

    btn.addEventListener("click", () => {
      const open = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", open ? "false" : "true");
      menu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>

<style>
  html[data-theme="dark"] .sun-icon { display: block; }
  html[data-theme="dark"] .moon-icon { display: none; }
  html:not([data-theme="dark"]) .sun-icon { display: none; }
  html:not([data-theme="dark"]) .moon-icon { display: block; }
</style>
