---
import type { CollectionEntry } from "astro:content";
import { calculateReadingTime } from "@/utils/readingTime";
import Datetime from "./Datetime.astro";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
}

const { variant = "h2", data, id, body } = Astro.props;
const { title, description, pubDatetime, modDatetime } = data;
const readingTime = calculateReadingTime(body ?? "");

const Tag = variant;
---

<li class="group py-6 first:pt-0">
  <a
    href={`/posts/${id}`}
    class="inline-block text-accent decoration-dashed underline-offset-4 focus-visible:no-underline"
  >
    <Tag class="font-display text-lg font-semibold tracking-tight decoration-dashed hover:underline">
      {title}
    </Tag>
  </a>
  <div class="flex items-center gap-2 mt-1.5">
    <Datetime {pubDatetime} {modDatetime} />
    <span class="text-subtle text-sm">&#183; {readingTime}</span>
  </div>
  <p class="mt-2 text-subtle leading-relaxed line-clamp-2">{description}</p>
</li>
