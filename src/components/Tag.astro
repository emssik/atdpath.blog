---
interface Props {
  tag: string;
  size?: "sm" | "md";
  linked?: boolean;
}

const { tag, size = "sm", linked = true } = Astro.props;
const sizeClasses = size === "md" ? "text-sm px-3 py-1" : "text-xs px-2 py-0.5";
const baseClasses = [
  "inline-block rounded-full border border-border text-subtle transition-all",
  "hover:border-accent/50 hover:text-accent hover:bg-accent/[0.06]",
  sizeClasses,
];
---

{linked ? (
  <a
    href={`/tags/${tag.toLowerCase()}`}
    class:list={baseClasses}
  >
    #{tag}
  </a>
) : (
  <span class:list={baseClasses}>
    #{tag}
  </span>
)}
