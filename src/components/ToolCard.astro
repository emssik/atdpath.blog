---
interface Props {
  title: string;
  url: string;
  icon?: string;
  id?: string;
}

const { title, url, icon, id } = Astro.props;
---

<div id={id} class="group my-3 first:mt-0 last:mb-0 rounded-lg border border-border bg-muted/20 px-5 py-4 transition-colors hover:border-accent/30 not-prose scroll-mt-24">
  <div class="mb-1.5 flex items-center gap-2">
    {icon && <span>{icon}</span>}
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="font-display font-semibold text-foreground decoration-accent/40 underline-offset-2 group-hover:text-accent transition-colors"
    >
      {title}
    </a>
  </div>
  <div class="text-subtle text-sm leading-relaxed sm:text-base [&_a]:text-accent [&_a]:underline [&_a]:decoration-accent/40 [&_a]:underline-offset-2">
    <slot />
  </div>
</div>
