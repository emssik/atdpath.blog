---
interface Props {
  kicker?: string;
  subtitle?: string;
}

const { kicker, subtitle } = Astro.props;
---

<section class="pt-12 pb-8">
  {kicker && (
    <p class="text-accent text-sm font-semibold tracking-widest uppercase mb-3">{kicker}</p>
  )}
  <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight leading-[1.15] mb-6">
    <slot />
  </h1>
  {subtitle && (
    <p class="text-subtle text-lg sm:text-xl leading-relaxed max-w-[38rem]">{subtitle}</p>
  )}
</section>
